{
  "name": "camisa-9",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "camisa-9 — jogo de carreira de futebol de baixa atenção (fundação Nexus Flow / H1VE). Monorepo TypeScript.",
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.typecheck.json",
    "build": "tsc -b",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.43",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
