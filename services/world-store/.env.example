# Copie para `.env` (git-ignorado) e ajuste. Server-only (OP-02/OP-12) — nunca commite o .env real.
# DEV LOCAL: aponta pro Postgres do docker-compose.yml (sem SSL). PRODUÇÃO: Neon — ver o exemplo
# comentado abaixo + docs/ops/neon-setup-runbook.md.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/camisa9_dev
# Se subir o compose com POSTGRES_PORT=5434 (5432 ocupada), troque a porta aqui também.

# MIGRATIONS no endpoint DIRECT (unpooled). Em dev local pode ficar vazio (cai na DATABASE_URL);
# em produção (Neon) = o host SEM `-pooler`.
# DATABASE_URL_UNPOOLED=

# --- Exemplo PRODUÇÃO (Neon) — formato apenas, NÃO ponha valores reais aqui (vão na plataforma) ---
# Use `sslmode=verify-full` (verifica o certificado à prova de futuro — ver ADR-002).
# DATABASE_URL=postgres://user:pass@ep-nome-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=verify-full
# DATABASE_URL_UNPOOLED=postgres://user:pass@ep-nome-123456.us-east-2.aws.neon.tech/neondb?sslmode=verify-full
