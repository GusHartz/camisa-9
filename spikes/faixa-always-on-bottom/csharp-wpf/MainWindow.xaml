<Window x:Class="FaixaSpike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="camisa-9 faixa (spike)"
        Height="40" Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        WindowStartupLocation="Manual"
        Background="#0B1220"
        ClipToBounds="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <!-- AllowsTransparency=false (default) de propósito: transparência liga a
         composição por-pixel do WPF e custa CPU. Fundo sólido.
         A cena anima um TranslateTransform.X (não Canvas.Left): transformações são
         processadas no render/composition thread, SEM disparar layout por frame —
         o caminho barato p/ o alvo < 1% CPU. O alvo do drift vem da LARGURA REAL
         (code-behind), cobrindo qualquer monitor. -->
    <Grid>
        <!-- Cena ambiente PLACEHOLDER: orbes em drift horizontal. -->
        <Canvas x:Name="Scene" ClipToBounds="True">
            <Ellipse Width="30" Height="30" Fill="#1E3A8A" Opacity="0.55" Canvas.Top="4">
                <Ellipse.RenderTransform><TranslateTransform x:Name="Orb1T" X="-60" /></Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="18" Height="18" Fill="#2563EB" Opacity="0.45" Canvas.Top="14">
                <Ellipse.RenderTransform><TranslateTransform x:Name="Orb2T" X="-60" /></Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="24" Height="24" Fill="#0EA5E9" Opacity="0.40" Canvas.Top="8">
                <Ellipse.RenderTransform><TranslateTransform x:Name="Orb3T" X="-60" /></Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="14" Height="14" Fill="#38BDF8" Opacity="0.50" Canvas.Top="20">
                <Ellipse.RenderTransform><TranslateTransform x:Name="Orb4T" X="-60" /></Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <TextBlock Foreground="#9CA3AF"
                   FontFamily="Segoe UI" FontSize="12"
                   VerticalAlignment="Center" HorizontalAlignment="Left"
                   Margin="16,0,0,0"
                   Text="camisa-9 · faixa always-on-bottom (spike)" />
        <TextBlock x:Name="ClockText"
                   Foreground="#E5E7EB"
                   FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Center" HorizontalAlignment="Right"
                   Margin="0,0,16,0"
                   Text="--:--:--" />
    </Grid>
</Window>
