<Window x:Class="WidgetTaskbar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WidgetTaskbar"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False" ShowActivated="False"
        AllowsTransparency="False" Topmost="False"
        Background="#1E1E28">
    <!-- AllowsTransparency=False: composição por-pixel custa CPU (memória do projeto). -->
    <Border Padding="8,2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Proxy animado: um ponto que desliza. TranslateTransform => render thread, sem layout. -->
            <Canvas x:Name="Track" Grid.Column="0" Width="40" Height="20" VerticalAlignment="Center">
                <Ellipse x:Name="Dot" Width="12" Height="12" Fill="#4EC9B0" Canvas.Top="4">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="DotX" />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <TextBlock x:Name="Status" Grid.Column="1" Margin="8,0,0,0"
                       Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="…" />
        </Grid>
    </Border>
</Window>
