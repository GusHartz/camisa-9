<Window x:Class="BandClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NEXT GOAT"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False" ShowActivated="False"
        AllowsTransparency="False" Topmost="False"
        Background="#101018"
        FontFamily="Segoe UI" Foreground="#E4E4EC">
    <!-- AllowsTransparency=False: composição por-pixel custa CPU (orçamento SPEC-003/042).
         Topmost=False no XAML: o topmost é setado no nível Win32 (TopmostStrip.Apply). -->
    <Window.Resources>
        <!-- Chip clicável (SPEC-045): um bloco de texto acionável, estrutural (sem arte). -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="#24303E" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <!-- SPEC-052 — a faixa em 3 camadas: (1) o CENÁRIO pixel-art (composto uma vez por chave em
         `SceneRenderer` e injetado pelo code-behind), (2) um scrim lateral que garante contraste do
         texto sobre qualquer fundo, (3) o conteúdo. O `PhaseBrush` fica como cor de base (aparece
         enquanto a cena não compôs e nas bordas). ClipToBounds só aqui, NUNCA no <Window>
         (crash de startup 0xE0434352). -->
    <Grid ClipToBounds="True" Background="{Binding PhaseBrush}">
        <Image x:Name="SceneLayer" Stretch="Fill"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#DB0B0F1C" Offset="0" />
                    <GradientStop Color="#8C0B0F1C" Offset="0.55" />
                    <GradientStop Color="#4D0B0F1C" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Border Padding="12,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Avatar + kit em BLOCOS DE COR (índices de appearance/kit → paleta estrutural; a arte
                 real — avatar em camadas — é fatia futura). -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                <Border Width="28" Height="16" Background="{Binding SkinBrush}" CornerRadius="2" />
                <Border Width="28" Height="8" Background="{Binding HairBrush}" CornerRadius="2"
                        Margin="0,2,0,0" />
                <StackPanel Orientation="Horizontal" Margin="0,3,0,0"
                            Visibility="{Binding KitVisible, Converter={StaticResource BoolToVis}}">
                    <Border Width="13" Height="10" Background="{Binding KitPrimaryBrush}" CornerRadius="2" />
                    <Border Width="13" Height="10" Background="{Binding KitSecondaryBrush}"
                            CornerRadius="2" Margin="2,0,0,0" />
                </StackPanel>
            </StackPanel>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Linha 1: atleta + fase -->
            <Grid Grid.Row="0">
                <TextBlock Text="{Binding AthleteLine}" FontWeight="SemiBold" FontSize="13"
                           TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Phase}" Foreground="#B7E4C7" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <!-- Linha 2: as DUAS barras persistentes (Forma, Moral) -->
            <Grid Grid.Row="1" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Forma" FontSize="10" Foreground="#9A9AA5"
                               Width="40" VerticalAlignment="Center" />
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding Forma}"
                                 Width="90" Height="8" Foreground="#4EC9B0" Background="#2A2A38"
                                 BorderThickness="0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Forma}" FontSize="10" Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Moral" FontSize="10" Foreground="#9A9AA5"
                               Width="40" VerticalAlignment="Center" />
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding Moral}"
                                 Width="90" Height="8" Foreground="#DDB86B" Background="#2A2A38"
                                 BorderThickness="0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Moral}" FontSize="10" Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Linha 3: clube + jogo do dia (durante o replay, o MatchLine vira o relógio+placar) -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ClubLine}" FontSize="11" Foreground="#C7C7D2"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="MatchLineText" Text="{Binding MatchLine}" FontSize="11"
                               Foreground="#9AD0FF" Margin="10,0,0,0"
                               TextTrimming="CharacterEllipsis" />
                    <!-- Flash do gol durante o replay (verde = seu, laranja = deles). Opacity 0/1 no
                         RENDER thread — nunca layout por frame (§184). -->
                    <TextBlock Text="⚽" FontSize="11" Foreground="#4EC9B0" Margin="6,0,0,0"
                               Opacity="{Binding MyGoalFlashOpacity}" />
                    <TextBlock Text="⚽" FontSize="11" Foreground="#F48771" Margin="6,0,0,0"
                               Opacity="{Binding TheirGoalFlashOpacity}" />
                </StackPanel>
                <TextBlock Text="{Binding QueueLine}" FontSize="11" Foreground="#DDB86B"
                           HorizontalAlignment="Right"
                           Visibility="{Binding QueueVisible, Converter={StaticResource BoolToVis}}" />
                <!-- Compartilhar o card + re-assistir (mutuamente exclusivos da fila). -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Card de partida (SPEC-049): gera a imagem 1080×1080 → clipboard + Pictures. -->
                    <TextBlock Text="📸 card" FontSize="10" Foreground="#DDB86B" Cursor="Hand"
                               Margin="0,0,10,0" VerticalAlignment="Center"
                               MouseLeftButtonDown="OnShareCardClick"
                               Visibility="{Binding CardAvailable, Converter={StaticResource BoolToVis}}" />
                    <!-- Re-assistir (clique simples): reproduz a última partida liquidada de novo. -->
                    <TextBlock Text="↻ re-assistir" FontSize="10" Foreground="#9AD0FF"
                               VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonDown="OnReWatchClick"
                               Visibility="{Binding ReplayAvailable, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>

            <!-- Linha 4: treino (com os botões de distribuir) · decisões · loja · regen · lesão + feedback/status -->
            <Grid Grid.Row="3" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TrainingLine}" FontSize="10" Foreground="#9A9AA5"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <!-- Distribuir 1 ponto (SPEC-045): os 4 chips aparecem quando há ponto livre. -->
                    <StackPanel Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding TrainingActionable, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Chip}" Tag="fisico" MouseLeftButtonDown="OnSpendClick">
                            <TextBlock Text="+Fís" FontSize="10" Foreground="#E4E4EC" />
                        </Border>
                        <Border Style="{StaticResource Chip}" Tag="tecnico" MouseLeftButtonDown="OnSpendClick">
                            <TextBlock Text="+Téc" FontSize="10" Foreground="#E4E4EC" />
                        </Border>
                        <Border Style="{StaticResource Chip}" Tag="tatico" MouseLeftButtonDown="OnSpendClick">
                            <TextBlock Text="+Tát" FontSize="10" Foreground="#E4E4EC" />
                        </Border>
                        <Border Style="{StaticResource Chip}" Tag="mental" MouseLeftButtonDown="OnSpendClick">
                            <TextBlock Text="+Men" FontSize="10" Foreground="#E4E4EC" />
                        </Border>
                    </StackPanel>
                    <!-- Decisões ▸ (abre o painel de decisão) -->
                    <TextBlock x:Name="DecisionTrigger" Text="{Binding DecisionsLine}" FontSize="10"
                               Foreground="#B7E4C7" Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonDown="OnDecisionsClick"
                               Visibility="{Binding HasDecisions, Converter={StaticResource BoolToVis}}" />
                    <!-- Loja ▸ -->
                    <TextBlock x:Name="ShopTrigger" Text="🛒 Loja" FontSize="10" Foreground="#9AD0FF"
                               Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonDown="OnShopClick"
                               Visibility="{Binding HasCatalog, Converter={StaticResource BoolToVis}}" />
                    <!-- Renascer carreira (raro): AÇÃO DESTRUTIVA (encerra a carreira na virada) →
                         confirmação em 2 passos + glifo próprio (⚑, não o ↻ do re-assistir). -->
                    <TextBlock Text="⚑ renascer carreira" FontSize="10" Foreground="#DDB86B"
                               Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonDown="OnRegenArmClick"
                               Visibility="{Binding RegenAvailable, Converter={StaticResource BoolToVis}}" />
                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding RegenConfirming, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="confirmar renascer?" FontSize="10" Foreground="#F48771"
                                   VerticalAlignment="Center" />
                        <Border Style="{StaticResource Chip}" MouseLeftButtonDown="OnRegenConfirmClick">
                            <TextBlock Text="sim" FontSize="10" Foreground="#E4E4EC" />
                        </Border>
                        <Border Style="{StaticResource Chip}" MouseLeftButtonDown="OnRegenCancelClick">
                            <TextBlock Text="não" FontSize="10" Foreground="#E4E4EC" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding InjuryLine}" FontSize="10" Foreground="#F48771"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding InjuryVisible, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActionFeedback}" FontSize="10" Foreground="#B7E4C7"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusLine}" FontSize="9" Foreground="#6A6A75" />
                </StackPanel>
            </Grid>
            </Grid>

            <!-- Painel de DECISÃO (SPEC-045): flutua acima da faixa; toggle no gatilho (StaysOpen). O
                 clique numa opção → POST /v1/decisions/answer → reconcilia → a próxima decisão aparece. -->
            <Popup IsOpen="{Binding DecisionOpen}" PlacementTarget="{Binding ElementName=DecisionTrigger}"
                   Placement="Top" VerticalOffset="-6" StaysOpen="True">
                <Border Background="#181820" BorderBrush="#2E2E3A" BorderThickness="1" Padding="10"
                        MaxWidth="380">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentDecision.Prompt}" Foreground="#E4E4EC"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding CurrentDecision.Options}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Chip}" Padding="8,4" Margin="0,0,6,0"
                                            MouseLeftButtonDown="OnDecisionOptionClick">
                                        <TextBlock Text="{Binding Label}" FontSize="11" Foreground="#E4E4EC" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- LOJA (SPEC-045): o catálogo; clicar "comprar" (só linhas disponíveis) → POST /v1/purchases. -->
            <Popup IsOpen="{Binding ShopOpen}" PlacementTarget="{Binding ElementName=ShopTrigger}"
                   Placement="Top" VerticalOffset="-6" StaysOpen="True">
                <Border Background="#181820" BorderBrush="#2E2E3A" BorderThickness="1" Padding="10"
                        MaxWidth="320" MaxHeight="220">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ShopItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3" Opacity="{Binding Dim}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11"
                                                   Foreground="#E4E4EC" VerticalAlignment="Center"
                                                   Margin="0,0,10,0" />
                                        <Border Grid.Column="1" Style="{StaticResource Chip}"
                                                IsHitTestVisible="{Binding CanBuy}"
                                                MouseLeftButtonDown="OnBuyClick">
                                            <TextBlock Text="{Binding Status}" FontSize="10"
                                                       Foreground="#E4E4EC" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>

            <!-- ESCOLHA NA PARTIDA (SPEC-050): o momento aparece NO MINUTO dele durante o replay
                 (dirigido pelo Frame — fora do replay não há affordance). Clicar numa opção →
                 POST /v1/matches/choices/answer → reconcilia; a arriscada leva o ⚡ATTR no rótulo. -->
            <!-- SPEC-051: o conteúdo é DESENHADO em `View/ChoiceCard.cs` (fiel ao handoff do Claude
                 Design, tratamento 1a) e injetado aqui pelo code-behind — o popup em si só ancora. -->
            <Popup IsOpen="{Binding ChoiceOpen}" PlacementTarget="{Binding ElementName=MatchLineText}"
                   Placement="Top" VerticalOffset="-4" StaysOpen="True" AllowsTransparency="True">
                <ContentControl x:Name="ChoiceHost" />
            </Popup>
        </Grid>
        </Border>
    </Grid>
</Window>
