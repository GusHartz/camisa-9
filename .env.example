# Variáveis de ambiente do scheduler de produção (SPEC-032/035). Copie para `.env` e preencha.
# NUNCA commite valores reais (OP-02/OP-12: segredos só via env server-only, jamais no repo).

# Connection string POOLED do Postgres (runtime/app). Em produção = Neon (endpoint com `-pooler`).
# Use `sslmode=verify-full` (não só `require`) → o `pg` deriva o SSL da URL e verifica o certificado
# à prova de futuro (ver ADR-002). O money path só usa advisory locks XACT-scoped → seguro no
# PgBouncer transaction-mode do endpoint pooled. Server-only.
DATABASE_URL=postgres://user:password@ep-nome-123456-pooler.us-east-2.aws.neon.tech/dbname?sslmode=verify-full

# Connection string DIRECT (unpooled) — usada SÓ pelas migrations (o migrator/DDL não deve
# depender do PgBouncer). Em produção = o mesmo host SEM o `-pooler`. Se ausente/vazia, as
# migrations caem na DATABASE_URL. Server-only.
DATABASE_URL_UNPOOLED=postgres://user:password@ep-nome-123456.us-east-2.aws.neon.tech/dbname?sslmode=verify-full

# A seed do mundo que este scheduler dirige (uma por processo; multi-seed = card futuro).
WORLD_SEED=

# --- API (SPEC-037) — o web service da camada HTTP/sessão -------------------------------------
# Porta de escuta. A plataforma normalmente injeta a dela; 3000 é só o default local.
PORT=3000

# Quantos proxies à frente da API são CONFIÁVEIS, para derivar o IP do cliente do `X-Forwarded-For`
# (toma o n-ésimo valor a partir da DIREITA — o que o proxy imediato escreveu e o cliente não
# controla). Railway/Render = 1.
# ⚠️ NÃO é cosmético: com `0` atrás de um proxy, TODOS os clientes caem no mesmo balde de rate
# limit (auto-DoS); confiando demais, o balde vira forjável e o limite por IP some.
TRUST_PROXY_HOPS=1
