# Variáveis de ambiente do scheduler de produção (SPEC-032). Copie para `.env` e preencha.
# NUNCA commite valores reais (OP-02/OP-12: segredos só via env server-only, jamais no repo).

# Connection string do Postgres (Neon em produção — driver pooled/TCP). Server-only.
DATABASE_URL=postgres://user:password@host:5432/dbname

# A seed do mundo que este scheduler dirige (uma por processo; multi-seed = card futuro).
WORLD_SEED=
